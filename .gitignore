```gitignore
# Dependencies
node_modules/

# Build output
dist/
dist-ssr/

# Environment variables
.env
.env.*
!.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Vite
.vite/

# Coverage
coverage/

# Cache
.cache/
.eslintcache

# Editor
.vscode/*
!.vscode/extensions.json
.idea/

# OS
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
*.swp
*.swo

# Local settings
*.local
```
